# AI — DeepSeek via Vercel AI Gateway (BYOK)
DEEPSEEK_API_KEY=sk-...
AI_GATEWAY_URL=https://ai-gateway.vercel.sh/v1/...

# Vercel Sandbox
VERCEL_SANDBOX_TEAM_ID=team_...
VERCEL_SANDBOX_API_TOKEN=...

# Cloudflare Pages
CF_ACCOUNT_ID=...
CF_API_TOKEN=...

# Unsplash
UNSPLASH_ACCESS_KEY=...

# App
NEXT_PUBLIC_APP_URL=https://yourplatform.com

# Durable runs (STEP 3) — server-chained continuation + cron sweeper
# Shared secret authenticating the internal /api/runs/continue + /api/runs/sweep calls.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set the SAME value in the Vercel project env (Production + Preview).
CM_INTERNAL_SECRET=
# Optional: force the base URL the chain self-invokes (defaults to VERCEL_URL / current deployment).
# CM_INTERNAL_BASE_URL=https://your-deployment.vercel.app
# Optional: Vercel Cron auth secret (if set, the cron sweeper also accepts Authorization: Bearer <CRON_SECRET>).
# CRON_SECRET=
